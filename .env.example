NODE_ENV=production
COMPOSE_PROJECT_NAME=etask

# Обязательные секреты. Не используйте одинаковые значения.
POSTGRES_PASSWORD=
BOOTSTRAP_ADMIN_PASSWORD=
JWT_SECRET=

# Публичный адрес локального сервера. Несколько адресов разделяются запятыми.
FRONTEND_ORIGIN=http://10.102.0.230
COOKIE_SECURE=false
JWT_EXPIRES_IN=8h

# API и журналирование.
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=1
JSON_BODY_LIMIT=2mb
UPLOAD_DIR=./storage/uploads

# Docker и резервное копирование.
ETASK_VERSION=1.0.0
ETASK_HTTP_PORT=80
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400

# Клиент использует тот же адрес, что и Nginx.
NEXT_PUBLIC_API_URL=/api

# Только для запуска без Docker:
# DATABASE_URL=postgres://etask:URL_ENCODED_PASSWORD@127.0.0.1:5432/etask
